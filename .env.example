# =============================================================================
# CiudadConecta — Variables de entorno (placeholders de ejemplo)
# Copia este archivo a .env.local y rellena con tus llaves reales.
# La app funciona en modo DEMO con datos mock si estas variables faltan.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CiudadConecta
NEXT_PUBLIC_DEFAULT_CITY=Cancún

# --- Autenticación: Clerk (usuarios y negocios) ---
# https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registro

# --- Base de datos: Neon PostgreSQL ---
# https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/ciudadconecta?sslmode=require

# --- Correos transaccionales: Resend ---
# https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hola@ciudadconecta.mx

# --- Pagos: Mercado Pago (planes de negocio LATAM) ---
# https://www.mercadopago.com.mx/developers
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxx

# --- Pagos: Stripe (alternativa internacional) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# --- Mapas: Google Maps (mapa interactivo) ---
# https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXX

# --- WhatsApp / SMS: Twilio (contacto con negocios) ---
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Almacenamiento de archivos (logos / fotos de negocio) ---
# Ej. Vercel Blob, UploadThing o S3
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx
